--- !u!114 &979736220
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 979736219}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 54da15041d3f5864c85d5cff83e7b5cb, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DLN.C3DLS_ExecuteDepthFirst
  recursiveMeaning: 'This component scans its transform subtree for C3DLS_LayoutOpsList
    components.


    It collects enabled lists, sorts them by pass number, and executes
    lower passes before higher passes.


    Search order is depth-first through
    the transform hierarchy. Within the same pass, execution order follows discovery
    order.


    If an ENABLED child or descendant C3DLS_ExecuteDepthFirst is encountered,
    that component is executed immediately and this search STOPS on that branch right
    there.


    That means a nested recursive executor becomes the local layout
    authority for its subtree. This helps prefabs encapsulate their own internal
    layout behavior and prevents double traversal of the same branch.


    If a
    nested recursive executor exists but is DISABLED, it does not block traversal.
    Search continues into that branch as normal.'
  includeSelfLists: 1
  skipDisabledLists: 1
  executeNestedRecursiveExecutors: 0
  stopAtNestedRecursiveExecutors: 0
  preventDuplicateNestedRecursiveExecution: 1
  verboseLogging: 0
